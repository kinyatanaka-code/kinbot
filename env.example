# --- 必須 ---
# Recall.ai の API キー（ダッシュボードで発行。生のキーをそのまま）
RECALL_API_KEY=
# Recall のリージョン（ダッシュボードに合わせる: us-west-2 / us-east-1 / eu-central-1 など）
RECALL_REGION=us-west-2
# Recall が Webhook を届ける先（公開URL）。例: https://xxxx.ngrok-free.app  末尾スラッシュ不要
PUBLIC_URL=

# --- 要約・提案のLLM（無料にするなら gemini か ollama） ---
# gemini / anthropic / ollama
LLM_PROVIDER=gemini

# Gemini（無料枠）: Google AI Studio で無料発行 https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash      # 最新のFlash系に変更可

# Anthropic（使う場合のみ）
ANTHROPIC_API_KEY=
ANALYZER_MODEL=claude-sonnet-4-6

# Ollama（ローカル・完全無料。使う場合のみ）
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# --- 任意 ---
PORT=8787
ANALYZE_INTERVAL_MS=12000
# Webhook 署名検証用（本番では設定し、verifyRecallRequest を公式検証に置換）
RECALL_WEBHOOK_SECRET=

# 公開時の簡易ログイン（設定推奨）。ブラウザでこのパスワードを聞かれる
APP_PASSWORD=

# Railway では PUBLIC_URL を空のままでOK（自動で公開ドメインを使用）。
# 自前ドメインや他環境では PUBLIC_URL を明示する。

# 文字起こしエンジン: recallai（標準・日本語は遅め）/ deepgram / gladia
RECALL_TRANSCRIBE_PROVIDER=recallai
DEEPGRAM_MODEL=nova-2

# 会議に表示されるBotの名前
BOT_NAME=議事録

# 履歴を保存するDB（Railwayで Postgres を追加すると自動で入る場合あり）。
# 未設定なら保存なしで動作（履歴は残らない）。
DATABASE_URL=

# Googleカレンダー連携（Google Cloud で OAuth クライアントを作成）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 無料LLM（Groq）を使う場合: LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 任意のOpenAI互換（Cerebras/OpenRouter等）: LLM_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# 個人アカウント（6人運用）: "ユーザー名:パスワード" をカンマ区切り
USERS=tanaka:pass1,sugiyama:pass2
# 全員のデータを見られる管理者（カンマ区切り）
ADMIN_USERS=tanaka
# Cookie署名用の秘密鍵（任意の長い文字列）
APP_SECRET=
# カレンダー自動入室商談の所有者（任意）
CALENDAR_OWNER=

# アカウント登録（メール＋パスワード）の制限（任意）
SIGNUP_CODE=            # 設定すると登録に合言葉が必要（社内限定向け・推奨）
ALLOWED_EMAIL_DOMAIN=   # 例 example.co.jp（このドメインのみ登録可）
ADMIN_EMAILS=           # 全員のデータを見られる管理者メール（カンマ区切り）

# 一次LLMが混雑(503)した時の自動切替先（任意。GROQ_API_KEYがあれば既定でgroqに切替）
FALLBACK_PROVIDER=groq

# 音声/動画アップロードの文字起こし用（どちらか必須）。Deepgramは話者分離あり。
DEEPGRAM_API_KEY=
# GROQ_API_KEY があれば Whisper でも文字起こし可能（話者分離なし）

# Salesforce連携（後日の連携作業で設定）
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com

# ライブ映像配信（Mux）。設定するとライブ商談に映像が付きます
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_LATENCY_MODE=low

# RAG（賢い検索）用の埋め込みモデル（既定: text-embedding-004。GEMINI_API_KEYを使用）
EMBED_MODEL=text-embedding-004

# 公式Google Drive Picker用（任意。未設定なら内製のドライブ閲覧にフォールバック）
GOOGLE_API_KEY=
GOOGLE_PROJECT_NUMBER=
